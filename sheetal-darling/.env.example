# ─────────────────────────────────────────────────────────────
# Sheetal Darling — environment configuration
# Everything is OPTIONAL. Without any keys the app runs fully
# offline using the built-in local companion brain, demo weather,
# live Hacker News, DuckDuckGo instant answers and procedural art.
# ─────────────────────────────────────────────────────────────

# OpenAI — upgrades the brain to GPT and enables real image generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=dall-e-3

# OpenWeatherMap — real-time weather instead of demo weather
OPENWEATHER_API_KEY=
